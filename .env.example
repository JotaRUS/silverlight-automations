NODE_ENV=development
PORT=3000
LOG_LEVEL=info

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/expert_sourcing
REDIS_URL=redis://localhost:6379
REDIS_NAMESPACE=local

JWT_ISSUER=expert-sourcing-platform
JWT_AUDIENCE=expert-sourcing-api
JWT_SECRET=replace-with-strong-secret
JWT_ACCESS_TOKEN_TTL_SECONDS=3600

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_CLASSIFICATION_TEMPERATURE=0.2

PROVIDER_ENCRYPTION_SECRET=replace-with-strong-provider-encryption-secret
