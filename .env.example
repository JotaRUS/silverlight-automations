NODE_ENV=development
PORT=3000
LOG_LEVEL=info

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/expert_sourcing
REDIS_URL=redis://localhost:6379
REDIS_NAMESPACE=local

JWT_ISSUER=expert-sourcing-platform
JWT_AUDIENCE=expert-sourcing-api
JWT_SECRET=replace-with-strong-secret
JWT_ACCESS_TOKEN_TTL_SECONDS=3600
# Public URL users open in the browser (admin + API). Stage: https://your-domain.example
EXTERNAL_APP_BASE_URL=http://localhost:3000
# LinkedIn OAuth callback — must exactly match an entry in LinkedIn Developer Portal → Auth → Authorized redirect URLs.
# If unset, defaults to ${EXTERNAL_APP_BASE_URL}/api/v1/providers/linkedin/oauth/callback
# LINKEDIN_OAUTH_REDIRECT_URI=https://your-domain.example/api/v1/providers/linkedin/oauth/callback

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_CLASSIFICATION_TEMPERATURE=0.2

PROVIDER_ENCRYPTION_SECRET=replace-with-strong-provider-encryption-secret
